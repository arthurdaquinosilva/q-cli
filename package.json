{
  "name": "@deaquinodev/querky",
  "version": "0.4.3",
  "description": "A quirky terminal SQL client with vim mode, AI features, and schema-aware autocomplete",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "querky": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup && chmod +x dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "Arthur D'Aquino <arthurdaquinosilva@gmail.com>",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "ink": "^7.0.3",
    "keytar": "^7.9.0",
    "mysql2": "^3.22.3",
    "pg": "^8.21.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
