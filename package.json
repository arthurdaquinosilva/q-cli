{
  "name": "q-cli",
  "version": "0.1.0",
  "description": "A beautiful SQL CLI with vim mode and AI features",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "q-cli": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup && chmod +x dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "Arthur D'Aquino <arthurdaquinosilva@gmail.com>",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  },
  "type": "module",
  "onlyBuiltDependencies": ["esbuild"],
  "dependencies": {
    "ink": "^7.0.3",
    "pg": "^8.21.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
